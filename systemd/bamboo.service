[Unit]
Description=Bamboo Cut Agent Stack
After=network-online.target systemd-user-sessions.service plymouth-quit-wait.service getty@tty1.service
Wants=network-online.target
Conflicts=getty@tty1.service
Before=getty.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/bamboo-cut-agent
Environment=API_HOST=0.0.0.0
Environment=API_PORT=8000
Environment=FRONTEND_HOST=0.0.0.0
Environment=FRONTEND_PORT=5173
Environment=BROWSER_HOST=127.0.0.1
Environment=BROWSER_BIN=/usr/bin/chromium
Environment=CAGE_BIN=/usr/bin/cage
Environment=CANMV_SERIAL_PORT=/dev/serial0
Environment=CANMV_BAUDRATE=115200
Environment=LIGHT_GPIO_PIN=10
Environment=LIGHT_LED_COUNT=16
Environment=LIGHT_BRIGHTNESS=255
Environment=VIDEO_DEVICE=/dev/v4l/by-id/usb-MACROSILICON_V-Z624_20210621-video-index0
Environment=VIDEO_WIDTH=1280
Environment=VIDEO_HEIGHT=720
Environment=VIDEO_FPS=30
Environment=VIDEO_ENCODER=x264enc
Environment=VIDEO_BITRATE_KBPS=2500
Environment=VIDEO_STUN_SERVER=
Environment=XDG_RUNTIME_DIR=/run/bamboo
Environment=WAYLAND_DISPLAY=wayland-1
RuntimeDirectory=bamboo
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes
StandardInput=tty
StandardOutput=journal
StandardError=journal
ExecStart=/home/pi/bamboo-cut-agent/scripts/start-bamboo.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
