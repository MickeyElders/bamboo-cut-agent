[Unit]
Description=Bamboo Cut Agent Frontend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/bamboo-cut-agent/frontend
Environment=FRONTEND_HOST=0.0.0.0
Environment=FRONTEND_PORT=5173
EnvironmentFile=-/home/pi/bamboo-cut-agent/systemd/bamboo.env
ExecStart=/usr/bin/npm run preview -- --host ${FRONTEND_HOST} --port ${FRONTEND_PORT}
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
